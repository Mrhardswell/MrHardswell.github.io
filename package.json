{
	"name": "mrhardswell-portfolio",
	"version": "1.0.0",
	"description": "My portfolio",
	"main": "index.html",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"serve": "live-server",
		"compile:scss": "sass --source-map scss/main.scss css/main.comp.css",
		"prefix:css": "postcss --use autoprefixer -b \"last 10 versions\" css/main.comp.css -o css/main.prefix.css",
		"compress:css": "sass --style=compressed css/main.prefix.css css/main.css",
		"build": "npm-run-all compile:scss prefix:css compress:css"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Mrhardswell/MrHardswell.github.io.git"
	},
	"keywords": [
		"html",
		"css",
		"scss",
		"javascript",
		"node",
		"npm"
	],
	"author": {
		"name": "MrHardswell",
		"url": "https://MrHardswell.github.io",
		"github": "https://github.com/MrHardswell",
		"twitter": "https://twitter.com/MrHardswell"
	},
	"license": "MIT",
	"devDependencies": {
		"autoprefixer": "^10.0.1",
		"live-server": "^1.2.2",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.1.1",
		"postcss-cli": "^8.1.0",
		"sass": "^1.69.0"
	}
}
